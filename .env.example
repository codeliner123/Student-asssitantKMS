# Copy this file to .env for local server-side configuration only.
# Never place secrets in static/ or commit them to source control.
GOOGLE_API_KEY=your_google_api_key_here

# Neo4j is optional. The dashboard starts with demo data when it is unavailable.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# Optional CSV path. Relative paths are resolved from this project directory.
DATASET_PATH=postings.csv
HOST=127.0.0.1
PORT=4173
